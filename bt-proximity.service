[Unit]
Description=Bluetooth Proximity Monitor — Suspend on Phone Away
After=bluetooth.service
Wants=bluetooth.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/bt-proximity/proximity_monitor.py
Restart=on-failure
RestartSec=5
TimeoutStopSec=10
StandardOutput=journal
StandardError=journal
StartLimitIntervalSec=60
StartLimitBurst=3

[Install]
WantedBy=multi-user.target
